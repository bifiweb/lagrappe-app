# ============================================================
# LA GRAPPE — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# Supabase — récupérer sur https://supabase.com/dashboard/project/[ton-projet]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role (uniquement côté serveur, jamais exposé au client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Shopify — récupérer dans Shopify Admin > Apps > Develop apps
NEXT_PUBLIC_SHOPIFY_DOMAIN=lagrappe.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Claude API — pour la génération des raisons de tiebreak
CLAUDE_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
